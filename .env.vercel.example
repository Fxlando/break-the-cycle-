PORT=3000
FRONTEND_URL=https://breakthecycle.network
NODE_ENV=production

# Recommended mode: hosted database + direct Vercel backend.
# Leave this blank unless you explicitly want Vercel to proxy API requests to
# your own PC through a tunnel.
EXTERNAL_API_ORIGIN=

# Use the Supabase Session pooler connection string here.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_PRICE_ID=price_xxx
STRIPE_MEMBERSHIP_PRICE_ID=price_membership_xxx
STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link
STRIPE_ACCOUNT_ID=acct_xxx

RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Break The Cycle <hello@breakthecycle.network>
EMAIL_REPLY_TO=breakthecyclework2025@gmail.com

POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com

SESSION_TTL_HOURS=720
ACCESS_CODE_LENGTH=10
SESSION_LOOKUP_TIMEOUT_MS=1200
DISABLE_SESSION_LOOKUP=0
ACCESS_CODE_DB_TIMEOUT_MS=1200
API_REQUEST_TIMEOUT_MS=12000
DB_OPERATION_TIMEOUT_MS=8000
EMAIL_SEND_TIMEOUT_MS=10000
MEMBERSHIP_SYNC_TTL_MS=300000

# Website-side Discord integration still needs these on Vercel.
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=discord_client_secret_here
DISCORD_REDIRECT_URI=https://breakthecycle.network/api/discord/callback
DISCORD_BOT_TOKEN=discord_bot_token_here
DISCORD_GUILD_ID=123456789012345678
DISCORD_ROLE_MEMBER_ID=123456789012345678
DISCORD_ROLE_CAREER_PIVOT_ID=123456789012345678
DISCORD_ROLE_SKILL_BUILD_ID=123456789012345678
DISCORD_ROLE_ROUTINE_RESET_ID=123456789012345678
DISCORD_ROLE_SIDE_PATHS_ID=123456789012345678
DISCORD_SERVER_INVITE_URL=https://discord.gg/replace-me
DISCORD_STATE_TTL_MS=900000
