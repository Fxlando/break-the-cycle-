{
  "name": "break-the-cycle",
  "version": "1.0.0",
  "description": "Landing + quiz with paywall-enabled backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "lint": "node -e \"console.log('No lint configured yet')\"",
    "ci": "npm run prisma:generate && npm run lint",
    "postinstall": "prisma generate",
    "build": "npm run prisma:generate && npx prisma db push --skip-generate --accept-data-loss 2>/dev/null || true"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "posthog-node": "^3.5.0",
    "resend": "^2.1.0",
    "serverless-http": "^3.2.0",
    "stripe": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.13.0"
  }
}
