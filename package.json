{
  "name": "break-the-cycle",
  "version": "1.0.0",
  "description": "Break the Cycle membership app with quiz, subscriptions, and Discord mentor bot",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "bot": "node bot.js",
    "bot:check": "node scripts/bot-preflight.js",
    "local:start": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-local.ps1",
    "local:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-local.ps1",
    "vercel:check": "node scripts/vercel-env-check.js",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "lint": "node -e \"console.log('No lint configured yet')\"",
    "ci": "npm run prisma:generate && npm run lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "posthog-node": "^3.5.0",
    "resend": "^2.1.0",
    "serverless-http": "^3.2.0",
    "stripe": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.13.0"
  }
}
