# This file is for the Discord bot running on your own machine.
# It should point at the same hosted Supabase database that Vercel uses.
NODE_ENV=production
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

DISCORD_BOT_TOKEN=discord_bot_token_here
DISCORD_GUILD_ID=123456789012345678
DISCORD_ROLE_MEMBER_ID=123456789012345678
DISCORD_ROLE_CAREER_PIVOT_ID=123456789012345678
DISCORD_ROLE_SKILL_BUILD_ID=123456789012345678
DISCORD_ROLE_ROUTINE_RESET_ID=123456789012345678
DISCORD_ROLE_SIDE_PATHS_ID=123456789012345678

MENTOR_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_REQUEST_TIMEOUT_MS=45000
MENTOR_DAILY_LIMIT=3
MENTOR_DM_SWEEP_INTERVAL_MS=21600000
