STRIPE_ACCOUNT_ID=acct_xxx
NODE_ENV=development
# Recommended: use the Supabase Session pooler string here for both the local app
# and the Vercel web app. Example shape:
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# If the direct database host is unreachable from your machine, use the same
# working pooler URL here too.
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
# Production example: EMAIL_FROM=Break The Cycle <hello@yourdomain.com>
EMAIL_REPLY_TO=breakthecyclework2025@gmail.com
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com
SESSION_TTL_HOURS=720
ACCESS_CODE_LENGTH=10
SESSION_LOOKUP_TIMEOUT_MS=1200
DISABLE_SESSION_LOOKUP=0
ACCESS_CODE_DB_TIMEOUT_MS=1200
API_REQUEST_TIMEOUT_MS=12000
DB_OPERATION_TIMEOUT_MS=8000
EMAIL_SEND_TIMEOUT_MS=10000
MEMBERSHIP_SYNC_TTL_MS=300000
